<Window x:Class="Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Setup.UI.ViewModels"
        xmlns:conv="clr-namespace:Setup.UI.Converters"
        mc:Ignorable="d"
        Title="Roblox Server Deployment"
        Height="720" Width="1040"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource MonoFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        d:DataContext="{x:Static vm:MainViewModel.DesignInstance}">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
            <conv:NullOrEmptyToCollapsedConverter x:Key="EmptyToCollapsed" />
            <conv:CountToVisibilityConverter x:Key="CountToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <!-- Root border keeps the rounded-corner illusion even without Mica. -->
    <Border Background="{StaticResource BgBrush}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- 0: title bar -->
                <RowDefinition Height="Auto" />   <!-- 1: banner -->
                <RowDefinition Height="Auto" />   <!-- 2: progress block -->
                <RowDefinition Height="Auto" />   <!-- 3: current task -->
                <RowDefinition Height="Auto" />   <!-- 4: checklist / downloads -->
                <RowDefinition Height="*" />      <!-- 5: log fills remaining -->
            </Grid.RowDefinitions>

            <!-- ===================== 0. TITLE BAR ===================== -->
            <Grid Grid.Row="0" Height="38" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="◆" Foreground="{StaticResource DownloadBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Setup.exe" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Text="— Roblox Server Deployment" Foreground="{StaticResource BorderBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}"
                            Content="&#xE921;" Click="OnMinimizeClick"
                            ToolTip="Minimize" />
                    <Button x:Name="CloseButton" Style="{StaticResource CloseButton}"
                            Content="&#xE8BB;" Click="OnCloseClick"
                            ToolTip="Close" />
                </StackPanel>
            </Grid>

            <!-- ===================== 1. BANNER ===================== -->
            <Border Grid.Row="1" Margin="20,4,20,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="BannerBox"
                               Foreground="{StaticResource DownloadBrush}"
                               FontSize="15"
                               TextAlignment="Center"
                               LineHeight="18"
                               FontWeight="Bold">
                        <Run Text="╔══════════════════════════════════════════╗" /><LineBreak />
                        <Run Text="║      " /><Run Text="{Binding BannerTitle}" Foreground="{StaticResource AccentBrush}" /><Run Text="      ║" /><LineBreak />
                        <Run Text="╚══════════════════════════════════════════╝" />
                    </TextBlock>
                    <TextBlock Text="{Binding PhaseText}"
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- ===================== 2. PROGRESS BLOCK ===================== -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="20,14,20,0">
                <StackPanel>
                    <Grid>
                        <ProgressBar Style="{StaticResource TerminalProgressBar}"
                                     Value="{Binding OverallProgress}" />
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Run Text="Elapsed " Foreground="{StaticResource MutedBrush}" /><Run Text="{Binding ElapsedText}" Foreground="{StaticResource TextBrush}" /><Run Text="   •   " Foreground="{StaticResource BorderBrush}" /><Run Text="ETA " Foreground="{StaticResource MutedBrush}" /><Run Text="{Binding EtaText}" Foreground="{StaticResource InfoBrush}" />
                        </TextBlock>
                        <TextBlock Text="{Binding PercentText}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource DownloadBrush}"
                                   FontWeight="Bold" FontSize="15" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===================== 3. CURRENT TASK ===================== -->
            <StackPanel Grid.Row="3" Margin="24,14,24,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Current Task:" Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding CurrentTask}"
                               Foreground="{StaticResource TextBrush}"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding CurrentFile}"
                           Foreground="{StaticResource DownloadBrush}"
                           FontSize="11.5"
                           Margin="0,3,0,0"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding CurrentFile, Converter={StaticResource EmptyToCollapsed}}" />
            </StackPanel>

            <!-- ===================== 4. CHECKLIST + DOWNLOAD ===================== -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Margin="20,14,20,0"
                    MaxHeight="170"
                    Visibility="{Binding TrackedItems.Count, Converter={StaticResource CountToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding TrackedItems}"
                                      Style="{StaticResource TransparentItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TrackedItem}">
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <TextBlock Text="{Binding Icon}"
                                                   Foreground="{Binding IconBrush}"
                                                   Width="22"
                                                   FontSize="13"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Live download line -->
                        <Border Margin="0,6,0,0"
                                Visibility="{Binding IsDownloadVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↓" Foreground="{StaticResource DownloadBrush}"
                                           Width="22" TextAlignment="Center"
                                           FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DownloadText}"
                                           Foreground="{StaticResource DownloadBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0" />
                                <TextBlock Text="{Binding DownloadSpeedText}"
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center" Margin="14,0,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===================== 5. LOG ===================== -->
            <Grid Grid.Row="5" Margin="20,14,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Log:" Style="{StaticResource MutedText}"
                           Margin="4,0,0,6" />

                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,10">
                    <ListBox x:Name="LogList"
                             Style="{StaticResource LogListBox}"
                             ItemsSource="{Binding LogLines}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TerminalLine}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp}"
                                               Foreground="{StaticResource BorderBrush}"
                                               FontSize="11.5"
                                               Margin="0,0,10,0"
                                               Visibility="{Binding HasTimestamp, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               Foreground="{Binding Brush}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- ===================== SUMMARY OVERLAY ===================== -->
            <Border Grid.Row="1" Grid.RowSpan="5"
                    Background="{StaticResource ScrimBrush}"
                    Visibility="{Binding IsSummaryVisible, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource Card}"
                        Background="{StaticResource PanelBrush}"
                        MaxWidth="720" MaxHeight="560"
                        Margin="40"
                        Padding="28,24"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF000000" BlurRadius="30" ShadowDepth="0" Opacity="0.55" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Headline -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,14">
                            <TextBlock Text="{Binding SummaryHeadline}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" />
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12,0,0" />
                        </StackPanel>

                        <!-- Result lists -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding SummaryInstalled}"
                                              Visibility="{Binding SummaryInstalled.Count, Converter={StaticResource CountToVis}}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,2">
                                                <Run Text="✔ " Foreground="{StaticResource SuccessBrush}" /><Run Text="{Binding Mode=OneWay}" Foreground="{StaticResource SuccessBrush}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding SummarySkipped}"
                                              Visibility="{Binding SummarySkipped.Count, Converter={StaticResource CountToVis}}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,2">
                                                <Run Text="↷ " Foreground="{StaticResource WarningBrush}" /><Run Text="{Binding Mode=OneWay}" Foreground="{StaticResource WarningBrush}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding SummaryFailed}"
                                              Visibility="{Binding SummaryFailed.Count, Converter={StaticResource CountToVis}}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,2">
                                                <Run Text="✖ " Foreground="{StaticResource ErrorBrush}" /><Run Text="{Binding Mode=OneWay}" Foreground="{StaticResource ErrorBrush}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{Binding SummaryOptimizations}"
                                              Visibility="{Binding SummaryOptimizations.Count, Converter={StaticResource CountToVis}}"
                                              Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,2">
                                                <Run Text="• " Foreground="{StaticResource InfoBrush}" /><Run Text="{Binding Mode=OneWay}" Foreground="{StaticResource InfoBrush}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <StackPanel Grid.Row="2" Margin="0,14,0,0">
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12" />
                            <TextBlock>
                                <Run Text="Total time  " Foreground="{StaticResource MutedBrush}" /><Run Text="{Binding SummaryElapsedText}" Foreground="{StaticResource TextBrush}" FontWeight="Bold" />
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0">
                                <Run Text="Logs  " Foreground="{StaticResource MutedBrush}" /><Run Text="{Binding SummaryLogPath}" Foreground="{StaticResource InfoBrush}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
